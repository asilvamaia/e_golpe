{
  "manifest_version": 3,
  "name": "Guardian Bot - É Golpe?",
  "version": "1.0",
  "description": "Analisa se a página atual é um ambiente seguro usando a inteligência do Guardian Bot.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
